generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

// ─── Modèles ─────────────────────────────────────────────

model User {
  id          String   @id @default(cuid())
  email       String   @unique
  password    String?
  nom         String
  siret       String?
  profession  String?
  regime      String   @default("DECLARATION_CONTROLEE")
  regimeTVA   String   @default("FRANCHISE")
  tauxTVA     Float    @default(20)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  exercices          ExerciceFiscal[]
  abonnement         Abonnement?
  transactionsBancaires TransactionBancaire[]
  motsCles           MotCle[]
  comptesBancaires   CompteBancaire[]
  declarations2035   Declaration2035[]

  // NextAuth
  accounts Account[]
  sessions Session[]
}

model ExerciceFiscal {
  id        String   @id @default(cuid())
  userId    String
  annee     Int
  dateDebut DateTime
  dateFin   DateTime
  statut    String   @default("OUVERT")
  createdAt DateTime @default(now())

  user      User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  ecritures EcritureComptable[]

  @@unique([userId, annee])
}

model EcritureComptable {
  id               String   @id @default(cuid())
  exerciceId       String
  date             DateTime
  libelle          String
  montant          Float
  sens             String
  rubrique2035Code String
  tvaCollectee     Float    @default(0)
  tvaDeductible    Float    @default(0)
  pieceRef         String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  exercice     ExerciceFiscal @relation(fields: [exerciceId], references: [id], onDelete: Cascade)
  rubrique2035 Rubrique2035   @relation(fields: [rubrique2035Code], references: [code])

  @@index([exerciceId, date])
}

model Rubrique2035 {
  code     String @id
  libelle  String
  type     String

  ecritures    EcritureComptable[]
  transactions TransactionBancaire[]
  motsCles     MotCle[]
}

// ─── Module Banque ───────────────────────────────────────

model TransactionBancaire {
  id               String   @id @default(cuid())
  userId           String
  date             DateTime
  libelleBancaire  String
  montant          Float
  tva              Float    @default(0)
  statut           String   @default("A_CATEGORISER")
  rubrique2035Code String?
  libelleComptable String?
  ecritureId       String?
  sens             String?
  createdAt        DateTime @default(now())

  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  rubrique2035 Rubrique2035? @relation(fields: [rubrique2035Code], references: [code])

  @@index([userId, statut])
  @@index([userId, date])
}

model MotCle {
  id               String   @id @default(cuid())
  userId           String
  motCle           String
  rubrique2035Code String
  sens             String
  tauxTVA          Float    @default(0)
  createdAt        DateTime @default(now())

  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  rubrique2035 Rubrique2035 @relation(fields: [rubrique2035Code], references: [code])

  @@unique([userId, motCle])
}

model CompteBancaire {
  id        String   @id @default(cuid())
  userId    String
  nom       String
  iban      String?
  solde     Float    @default(0)
  updatedAt DateTime @updatedAt

  user            User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  soldesInitiaux  SoldeInitial[]
}

model SoldeInitial {
  id               String   @id @default(cuid())
  compteBancaireId String
  annee            Int
  montant          Float    @default(0)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  compteBancaire CompteBancaire @relation(fields: [compteBancaireId], references: [id], onDelete: Cascade)

  @@unique([compteBancaireId, annee])
}

// ─── Déclaration 2035 ────────────────────────────────────

model Declaration2035 {
  id           String    @id @default(cuid())
  userId       String
  annee        Int
  statut       String    @default("BROUILLON")
  snapshot     String?
  validatedAt  DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, annee])
}

// ─── Abonnement ──────────────────────────────────────────

model Abonnement {
  id               String   @id @default(cuid())
  userId           String   @unique
  stripeCustomerId String?
  plan             String   @default("ESSENTIEL")
  statut           String   @default("ESSAI")
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ─── NextAuth Models ─────────────────────────────────────

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}
